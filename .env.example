# Database
DATABASE_URL="postgresql://user:password@localhost:5432/formpilot"

# Auth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Encryption (required — encrypts SSN, passport, etc. in profile data)
# Generate with: openssl rand -base64 32
PROFILE_ENCRYPTION_KEY=""

# Anthropic
ANTHROPIC_API_KEY=""

# App URL (used for CORS allow-list — set to your Vercel deployment URL in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

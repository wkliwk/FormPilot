# Database
# For Railway production, add connection pool params to handle traffic spikes:
# DATABASE_URL="postgresql://user:password@host:5432/formpilot?connection_limit=10&pool_timeout=30"
DATABASE_URL="postgresql://user:password@localhost:5432/formpilot"

# Auth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3300"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Encryption (required — encrypts SSN, passport, etc. in profile data)
# Generate with: openssl rand -base64 32
PROFILE_ENCRYPTION_KEY=""

# Anthropic (Claude) — used for image/vision analysis
ANTHROPIC_API_KEY=""

# Groq — primary text AI for form analysis (console.groq.com)
GROQ_API_KEY=""

# OpenRouter — fallback text AI when Groq is rate-limited (openrouter.ai)
# Default: "openrouter/free" — auto-routes to any available free model (most resilient)
# Override via OPENROUTER_MODEL to pin a specific model
OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="openrouter/free"

# App URL (used for CORS allow-list — set to your Vercel deployment URL in production)
NEXT_PUBLIC_APP_URL="http://localhost:3300"

# Stripe billing (get keys from dashboard.stripe.com)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Price ID for the $9/month Pro plan (from Stripe Dashboard → Products)
STRIPE_PRO_PRICE_ID=""
# Webhook secret from Stripe Dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=""

# Cron job authentication (used by /api/cron/* routes)
# Generate with: openssl rand -hex 32
CRON_SECRET=""
# Days before an in-progress fill session is cleared (default: 30)
SESSION_EXPIRY_DAYS="30"

# Pro plan price displayed on landing page pricing section
NEXT_PUBLIC_PRO_PRICE="$9/mo"

# Feature flags
SHOW_TESTIMONIALS="false"
# Set to "true" in local dev to allow email sends (requires RESEND_API_KEY)
SEND_EMAILS="false"

# Resend transactional email (get API key from resend.com)
RESEND_API_KEY=""

# Sentry error tracking (get DSN from sentry.io → Project Settings → Client Keys)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Generate at sentry.io → Settings → Auth Tokens (needed for source map uploads on deploy)
SENTRY_AUTH_TOKEN=""

{
  "name": "formpilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3300",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "build:check": "prisma generate && next build",
    "build:extension": "cd extension && zip -r ../public/formpilot-extension.zip . --exclude '*.DS_Store' --exclude 'icons/generate-icons.js' && echo 'Extension zip written to public/formpilot-extension.zip'"
  },
  "prisma": {
    "seed": "npm run db:seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@auth/prisma-adapter": "^2.7.4",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.0.0",
    "@react-email/components": "^1.0.10",
    "@react-email/render": "^2.0.4",
    "@sentry/nextjs": "^10.46.0",
    "@types/jszip": "^3.4.0",
    "@types/qrcode": "^1.5.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "canvas": "^3.2.2",
    "canvas-confetti": "^1.9.4",
    "groq-sdk": "^1.1.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.25",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.5.207",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-pdf": "^10.4.1",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "resend": "^6.9.4",
    "sharp": "^0.34.5",
    "stripe": "^21.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.31.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "15.2.3",
    "jest": "^30.3.0",
    "postcss": "^8.5.8",
    "prisma": "^7.0.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  referralCode          String?   @unique // Short code for referral links (generated on first use)
  referredBy            String?           // userId of the user who referred this user
  reminderEmailsEnabled    Boolean   @default(true) // Set false via unsubscribe link to opt out of nudge emails
  lastSeenChangelogAt      DateTime? // Last time user opened the What's New drawer
  lastDigestSentAt         DateTime? // Last time a stale-form digest was sent to this user
  digestUnsubscribed       Boolean   @default(false) // Set true via digest unsubscribe link

  accounts     Account[]
  sessions     Session[]
  profile      Profile?
  forms        Form[]
  templates    FormTemplate[]
  formMemory   FormMemory[]
  subscription Subscription?
  usage        UsageCount?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Encrypted personal data profile for autofill
model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  data              Json     // Encrypted profile fields (name, DOB, address, etc.)
  preferredLanguage String?  // ISO 639-1 code, e.g. "es", "zh", "ko". Null = English.
  country           String?  // ISO 3166-1 alpha-2 country code (e.g. "US", "HK")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Represents a form session (uploaded or web form)
model Form {
  id          String     @id @default(cuid())
  userId      String
  title       String
  sourceType  SourceType
  sourceUrl   String?    // For web forms
  fileKey     String?    // S3/storage key for uploaded files (reserved for future use)
  fileBytes   Bytes?     // Raw uploaded file bytes for PDF re-fill on export
  fields      Json       // Parsed field definitions
  filledData  Json?      // Autofilled values
  language    String     @default("en") // Active explanation language (ISO 639 code)
  status      FormStatus @default(PENDING)
  category     String?    // Detected form category (TAX, IMMIGRATION, LEGAL, HR_EMPLOYMENT, HEALTHCARE, GENERAL)
  lastNudgedAt DateTime? // Set after sending re-engagement email — suppresses nudges for 7 days
  shareToken   String?   @unique // nanoid(16) — public share link token; null = not shared
  version      Int       @default(0) // Optimistic lock counter — incremented on every field-values write
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum SourceType {
  PDF
  WORD
  WEB
  SPREADSHEET
  IMAGE
}

enum FormStatus {
  PENDING
  ANALYZED
  FILLING
  COMPLETED
}

// Global cache for AI-generated field explanations, keyed by normalized label+type.
// Shared across all users — field explanations are not user-specific.
model FieldCache {
  id             String   @id @default(cuid())
  cacheKey       String   @unique // "{normalized_label}:{type}", e.g. "first_name:text"
  explanation    String
  example        String
  commonMistakes String
  whereToFind    String?
  profileKey     String?
  hitCount       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  expiresAt      DateTime

  @@index([expiresAt])
}

// Per-user structured memory extracted from completed forms
model FormMemory {
  id           String   @id @default(cuid())
  userId       String
  fieldType    String   // name | email | phone | address | employer | passport | tax_id | custom
  label        String   // Normalized field label (lowercase, stripped punctuation)
  value        String
  confidence   Float    @default(1.0)
  sourceFormId String
  sourceTitle  String
  lastUsed     DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, label])
  @@index([userId, fieldType])
}

// Stripe subscription record
model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  stripeCustomerId       String             @unique
  stripeSubscriptionId   String?            @unique
  status                 SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INACTIVE
}

// Monthly form upload usage counter per user (resets on billing cycle)
model UsageCount {
  id               String    @id @default(cuid())
  userId           String    @unique
  formsThisMonth   Int       @default(0)
  bonusForms       Int       @default(0) // Extra forms earned via referrals (max 5)
  periodStart      DateTime  @default(now())
  quotaNudgeSentAt DateTime? // Set after sending quota-approaching email — suppresses re-sends
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Shareable form templates — strips personal values, preserves form structure + guidance
// Persistent rate limit counters — replaces in-memory Map for serverless-safe enforcement
model RateLimit {
  id         String   @id @default(cuid())
  key        String   @unique // "{userId}:{action}", e.g. "clxyz:profile_import"
  count      Int      @default(0)
  windowStart DateTime // Start of the current rate limit window
  updatedAt  DateTime @updatedAt

  @@index([key])
}

model FormTemplate {
  id           String    @id @default(cuid())
  userId       String
  name         String
  sourceFormId String
  fields       Json      // Field structure with AI guidance — personal values stripped
  category     String?
  slug         String?   @unique // URL slug for sharing: /t/[slug]
  visibility   String    @default("INVITE") // "PUBLIC" or "INVITE"
  usedCount    Int       @default(0)
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([slug])
}

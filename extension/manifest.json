{
  "manifest_version": 3,
  "name": "FormPilot",
  "version": "0.1.0",
  "description": "AI-powered form assistant — get plain-language field explanations and smart autofill on any web form.",
  "permissions": ["activeTab", "sidePanel", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "FormPilot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

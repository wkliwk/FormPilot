# Copy to .env.local for local development.
# Dummy values below allow `npm run build:check` to run without a live DB.

DATABASE_URL=postgresql://dummy:dummy@localhost:5432/formpilot
NEXTAUTH_URL=http://localhost:3300
NEXTAUTH_SECRET=dummy-secret-32-chars-minimum-here
AUTH_SECRET=dummy-secret-32-chars-minimum-here
PROFILE_ENCRYPTION_KEY=dummy-encryption-key-32-chars-ok
GITHUB_ID=dummy
GITHUB_SECRET=dummy
GOOGLE_CLIENT_ID=dummy
GOOGLE_CLIENT_SECRET=dummy
ANTHROPIC_API_KEY=sk-ant-dummy
GROQ_API_KEY=gsk_dummy
